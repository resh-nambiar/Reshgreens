### **1. Create a new database**

CREATE DATABASE company_db;

### **2. Select the database**

USE company_db;

### **3. Create `skills` table**

CREATE TABLE skills (
    skill_id INT AUTO_INCREMENT PRIMARY KEY,
    skill_name VARCHAR(100) NOT NULL,
    category VARCHAR(100)
);

### **4. Show all databases**

SHOW DATABASES;

### **5. Show all tables in `company_db`**


SHOW TABLES;

### **6. Rename `employee` table to `staff`**

RENAME TABLE employee TO staff;
### Data Insertion

### 7. Insert a record into employee

INSERT INTO employee (first_name, email, hire_date, salary, dept_id, gender)
VALUES ('Alice Green', 'alice.green@company.com', '2024-01-10', 62000.00, 4, 'Female');

### 8. Insert multiple records into project

INSERT INTO project (project_name, budget, dept_id)
VALUES 
('Mobile App', 60000.00, 2),
('Training Program', 25000.00, 1);

### 9. Insert into department

INSERT INTO department (dept_name, location)
VALUES ('Sales', 'Boston');

### 10. Insert partial data into employee

INSERT INTO employee (first_name, email)
VALUES ('Tom', 'tom@company.com');


### Data Retrieval

### 11. Retrieve all records from employee

SELECT * FROM employee;

### 12. Select specific columns with aliases

SELECT 
    emp_id AS "Employee ID",
    first_name AS "Name",
    email AS "Email Address"
FROM employee;

### 13. Employees hired after Jan 1, 2023

SELECT * 
FROM employee
WHERE hire_date > '2023-01-01';

### 14. Projects with budget > 40000 (descending order)

SELECT * 
FROM project
WHERE budget > 40000.00
ORDER BY budget DESC;

### 15. Distinct locations from department

SELECT DISTINCT location 
FROM department;

#  **Data Modification**

### **16. Add column after email**

ALTER TABLE employee
ADD phone_number VARCHAR(15) AFTER email;


### **17. Update salary of John Doe**

UPDATE employee
SET salary = 65000.00
WHERE first_name = 'John Doe';


### **18. Update gender for IT department**


UPDATE employee
SET gender = 'Other'
WHERE dept_id = 2;


### **19. Drop column**


ALTER TABLE employee
DROP COLUMN phone_number;


# **Filtering and Conditions**

### **20. Salary between 60000 and 80000**


SELECT * FROM employee
WHERE salary BETWEEN 60000 AND 80000;


### **21. Names starting with J**

SELECT * FROM employee
WHERE first_name LIKE 'J%';

### **22. Projects in dept 1 or 2**


SELECT * FROM project
WHERE dept_id IN (1, 2);

### **23. Email not NULL**

SELECT * FROM employee
WHERE email IS NOT NULL;


### **24. Departments not in NY or Chicago**

SELECT * FROM department
WHERE location NOT IN ('New York', 'Chicago');


### **25. Employees hired in 2023**


SELECT * FROM employee
WHERE YEAR(hire_date) = 2023;

#  **Aggregate Functions**

### **26. Total salary**


SELECT SUM(salary) AS total_salary FROM employee;


### **27. Average project budget**


SELECT AVG(budget) AS avg_budget FROM project;


### **28. Highest salary**


SELECT MAX(salary) AS highest_salary FROM employee;


### **29. Count employees in IT**


SELECT COUNT(*) AS total_employees
FROM employee
WHERE dept_id = 2;


### **30. Minimum project budget**


SELECT MIN(budget) AS min_budget FROM project;


#  **Joins**

### **31. Employees with department names**


SELECT e.*, d.dept_name
FROM employee e
JOIN department d ON e.dept_id = d.dept_id;

### **32. Departments with employee count (including empty)**


SELECT d.dept_name, COUNT(e.emp_id) AS employee_count
FROM department d
LEFT JOIN employee e ON d.dept_id = e.dept_id
GROUP BY d.dept_name;

### **33. Projects with department names**


SELECT p.project_name, d.dept_name
FROM project p
JOIN department d ON p.dept_id = d.dept_id;

### **34. Employees in San Francisco departments**


SELECT e.*
FROM employee e
JOIN department d ON e.dept_id = d.dept_id
WHERE d.location = 'San Francisco';


### **35. Departments with no projects**


SELECT d.dept_name
FROM department d
LEFT JOIN project p ON d.dept_id = p.dept_id
WHERE p.project_id IS NULL;


# **String & Numeric Functions**

### **36. Full Name**

SELECT CONCAT(first_name, ' ', last_name) AS "Full Name"
FROM employee;

### **37. Uppercase department names**


SELECT UPPER(dept_name) FROM department;

### **38. First 3 characters of email**


SELECT SUBSTRING(email, 1, 3) FROM employee;

### **39. Absolute value**

SELECT ABS(-50000);

### **40. Rounded average salary**

SELECT ROUND(AVG(salary), 2) FROM employee;


#  **Advanced Queries**

### **41. First 3 records (latest hires)**


SELECT * FROM employee
ORDER BY hire_date DESC
LIMIT 3;


### **42. Pagination (records 4–6)**


SELECT * FROM employee
ORDER BY emp_id
LIMIT 3 OFFSET 3;


### **43. IF salary classification**


SELECT first_name,
IF(salary >= 70000, 'High', 'Low') AS salary_category
FROM employee;

### **44. CASE for project budget**


SELECT project_name,
CASE
    WHEN budget >= 60000 THEN 'Large'
    WHEN budget >= 40000 THEN 'Medium'
    ELSE 'Small'
END AS budget_category
FROM project;

### **45. Total budget per department**


SELECT dept_id, SUM(budget) AS total_budget
FROM project
GROUP BY dept_id;


### **46. Employee with longest name**

SELECT *
FROM employee
ORDER BY LENGTH(first_name) DESC
LIMIT 1;

### **47. Employees hired in last 90 days (from 2025-03-22)**


SELECT *
FROM employee
WHERE hire_date >= DATE_SUB('2025-03-22', INTERVAL 90 DAY);

#  **Deletion & Cleanup**

### **48. Delete employees with low salary**


DELETE FROM employee
WHERE salary < 60000;


### **49. Drop project table**


DROP TABLE project;


### **50. Backup & Restore (MySQL example)**

mysql -u username -p company_db < backup.sql

